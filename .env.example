# Environment configuration for Recipe to Bring App
# Copy this file to .env and fill in the required values

# --- Required secrets ---
OPENAI_API_KEY=
SECRET_KEY=                    # random string for JWT signing; e.g. openssl rand -hex 32

# --- Application ---
APP_VERSION=1.0.0
USERS_FILE=users.json          # path (inside backend container) to the seed users file

# --- Training-data collection (opt-in, for the image-ingestion eval) ---
# When enabled, each image import saves the uploaded image + the raw model
# extraction so your later edits become ground-truth labels. Needs a persisted
# volume for TRAINING_DATA_DIR before enabling in production.
COLLECT_TRAINING_DATA=         # 1/true/on to enable; empty = off (default)
TRAINING_DATA_DIR=training_data  # dir (inside backend container) for collected pairs

# --- URLs injected into the frontend via nginx sub_filter ---
API_URL=https://bring.vimi.run/api   # public URL clients use to reach the API
FRONTEND_URL=https://bring.vimi.run  # public URL of the frontend
SERVER_NAME=bring.vimi.run           # nginx server_name (must match TLS certificate)

# --- Ports ---
NGINX_PORT=80                  # host port that nginx listens on
BACKEND_PORT=8001              # internal port; rarely needs changing

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=bring_importer

# Note: BACKEND_URL, FRONTEND_ROOT, NGINX_USER, NGINX_LOGDIR are no longer needed.
# docker-compose sets BACKEND_URL=http://backend:8001 internally.
