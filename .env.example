# Environment configuration example for Recipe to Bring App
# Copy this file to .env and adjust values as needed

# Application version
APP_VERSION=1.0.0

# Frontend root directory (absolute path) - MUST be updated to your actual path
FRONTEND_ROOT=/path/to/your/bring_importer/frontend

# API configuration
API_URL=http://localhost:8001
FRONTEND_URL=http://localhost

# Backend configuration 
BACKEND_URL=http://localhost:8001

# Server ports
NGINX_PORT=80
BACKEND_PORT=8001
NGINX_LOGDIR=
NGINX_USER="michael"
NGINX_USER_GROUP="staff"